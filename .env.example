# Example `.env` for the server
# Copy this file to `.env` and fill the values. DO NOT commit `.env` to Git.

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/workforce

# Application port
PORT=5000

# JWT secret (use a long, random value)
JWT_SECRET=replace_with_a_long_random_string

# Client URL for CORS
CLIENT_URL=http://localhost:3000

# Optional SMTP/email settings (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@email.com
EMAIL_PASS=your-email-password-or-app-password
# =========================================================================
# WorkSync Pro — Backend Environment Configuration Template
# Set these variables directly in your Render Web Service Dashboard settings
# =========================================================================

# The port Express runs on (Render sets this automatically, but local uses 5001)
PORT=5001

# Your MongoDB Database Connection URI (e.g. MongoDB Atlas Connection String)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/database_name

# JSON Web Token secret key for user sessions (provide a long random string)
JWT_SECRET=your_jwt_signing_secret_key_here

# Optional: Email Service Credentials (for automated notifications, alerts)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Optional: Frontend Client Domain (e.g. https://your-app.onrender.com)
FRONTEND_URL=https://your-app-domain.onrender.com

# Cloudinary Configuration (Set these in Render for persistent receipt uploads)
CLOUDINARY_CLOUD_NAME=divvkfqga
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
